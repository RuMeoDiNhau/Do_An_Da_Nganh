# Server
PORT=3001
NODE_ENV=development

# Startup requirements
# REQUIRE_DB=true
# REQUIRE_MQTT=true

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=smarthome-api
JWT_AUDIENCE=smarthome-client
AUTH_ALLOWED_ROLES=user,admin

# Postgres (used by Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yolohome?schema=public"

# MQTT
MQTT_URL="mqtt://localhost:1883"
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_TELEMETRY="yolohome/telemetry"
MQTT_TOPIC_CONTROL="yolohome/control"